# MongoDB Atlas Connection String
# Replace with your actual MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/databasename?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/watermonitor?retryWrites=true&w=majority

# Server Port
PORT=5000

# Node Environment
# Use 'development' for local testing, 'production' for Render
NODE_ENV=production

# CORS Origin - Update with your frontend URL
# Local: http://localhost:5173
# Production: https://your-frontend-url.onrender.com
CORS_ORIGIN=https://your-frontend-url.onrender.com
